# Copy to .env.local for local dev, or set these in your deploy target.

# Set to "true" to run the UI entirely on mock data with no backend running —
# useful for frontend-only work or demos. Defaults to false.
VITE_USE_MOCKS=false

# Used by vite.config.ts dev proxy only (not read by the app at runtime).
VITE_API_TARGET=http://localhost:8000

# Production build: base URL for REST calls. Leave unset in dev — the
# Vite proxy handles /api routing to VITE_API_TARGET instead.
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# Production build: base URL for the WebSocket connection.
# VITE_WS_BASE_URL=wss://api.yourdomain.com
