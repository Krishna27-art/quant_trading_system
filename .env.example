# Angel One SmartAPI Credentials
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_CLIENT_CODE=your_client_code_here
ANGEL_ONE_PASSWORD=your_password_here
ANGEL_ONE_TOTP=your_totp_secret_here

# Zerodha Kite credentials used by the live broker adapter and standalone kill switch
ZERODHA_API_KEY=replace_with_real_key
ZERODHA_ACCESS_TOKEN=replace_with_real_access_token

# Database
POSTGRES_USER=replace_with_db_user
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=quant_terminal
DATABASE_URL=postgresql://replace_with_db_user:replace_with_strong_password@localhost:5432/quant_terminal
DATABASE_URL_ASYNC=postgresql+asyncpg://replace_with_db_user:replace_with_strong_password@localhost:5432/quant_terminal
REDIS_URL=redis://localhost:6379/0
USE_REDIS=true

# API security
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_admin_password
JWT_SECRET_KEY=replace_with_256_bit_random_secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
KILL_SWITCH_DRY_RUN=true
KILL_SWITCH_LOG=logs/kill_switch.log

# Monitoring
GRAFANA_ADMIN_PASSWORD=replace_with_strong_grafana_password
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
