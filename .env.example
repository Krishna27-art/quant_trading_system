# Angel One SmartAPI Credentials
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_CLIENT_CODE=your_client_code_here
ANGEL_ONE_PASSWORD=your_password_here
ANGEL_ONE_TOTP=your_totp_secret_here

#upstox broker credentials
UPSTOX_BROKER_API_KEY=your_upstox_api_key_here
API_SECRET=your_upstox_api_secret_here
UPSTOX_BROKER_ACCESS_TOKEN=your_upstox_access_token_here

# Zerodha Kite credentials
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_SECRET=your_zerodha_secret_here

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=quant
DATABASE_URL=sqlite:///quant.db
DATABASE_URL_ASYNC=sqlite+aiosqlite:///quant.db
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# API security
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_admin_password
JWT_SECRET_KEY=replace_with_256_bit_random_secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
KILL_SWITCH_DRY_RUN=true
KILL_SWITCH_LOG=logs/kill_switch.log

# Monitoring
GRAFANA_ADMIN_PASSWORD=replace_with_strong_grafana_password
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
